{
    "enable_keyword_switching": {
    "description": "启用关键词切换",
    "hint": "关闭后仍然可以使用指令切换。",
    "type": "bool",
    "default": true
  },
  "keyword_mappings": {
    "description": "关键词与人格切换映射列表",
    "hint": "每项填写一个映射字符串，格式为 关键词:人格ID；也支持在配置里直接填写对象形式。",
    "type": "list",
    "default": ["关键词:人格"]
  },
  "auto_switch_scope": {
    "description": "切换作用范围",
    "hint": "决定切换后人格应用于当前对话、会话或全局",
    "type": "string",
    "default": "conversation",
    "options": [
      "conversation",
      "session",
      "global"
    ]
  },
  "manage_wait_timeout_seconds": {
    "description": "管理指令等待超时时长",
    "hint": "创建或更新人格时等待用户发送内容的最长时间(秒)",
    "type": "int",
    "default": 60
  },
  "admin_commands": {
    "description": "需要管理员权限的指令配置",
    "hint": "以对象形式配置指令是否需要管理员权限；值为 true 表示需要管理员权限，false 表示普通用户可用。",
    "type": "object",
    "items": {
      "switch": {
        "type": "bool",
        "description": "快捷切换人格",
        "hint": "是否要求管理员权限",
        "default": false
      },
      "create": {
        "type": "bool",
        "description": "创建人格",
        "hint": "是否要求管理员权限",
        "default": true
      },
      "update": {
        "type": "bool",
        "description": "更新人格",
        "hint": "是否要求管理员权限",
        "default": true
      },
      "delete": {
        "type": "bool",
        "description": "删除人格",
        "hint": "是否要求管理员权限",
        "default": true
      },
      "view": {
        "type": "bool",
        "description": "查看人格详情",
        "hint": "是否要求管理员权限",
        "default": false
      },
      "avatar": {
        "type": "bool",
        "description": "上传人格头像",
        "hint": "是否要求管理员权限",
        "default": true
      },
      "list": {
        "type": "bool",
        "description": "列出人格",
        "hint": "是否要求管理员权限",
        "default": false
      },
      "help": {
        "type": "bool",
        "description": "查看帮助",
        "hint": "是否要求管理员权限",
        "default": false
      }
    }
  },
  "enable_llm_tools": {
    "description": "启用函数工具",
    "hint": "开启后会向 LLM 暴露人格列表、查看、切换、创建、更新、删除等函数工具。",
    "type": "bool",
    "default": false
  },
  "enable_auto_switch_announce": {
    "description": "切换提示",
    "hint": "切换人格时，是否发送提示",
    "type": "bool",
    "default": true
  },
  "clear_context_on_switch": {
    "description": "切换后清空上下文",
    "hint": "启用后，切换人格后会自动清空当前对话上下文，不需要手动reset",
    "type": "bool",
    "default": false
  },
  "sync_nickname_on_switch": {
    "description": "修改 QQ 昵称",
    "hint": "是否在切换人格时改变 QQ 昵称(仅适配NapCat!!!)",
    "type": "bool",
    "default": true
  },
  "nickname_sync_mode": {
    "description": "昵称同步模式",
    "hint": "profile: 仅修改QQ昵称; group_card: 群聊中仅修改群名片,私聊不修改; hybrid: 群聊中修改群名片,私聊中修改QQ昵称。",
    "type": "string",
    "default": "group_card",
    "options": [
      "profile",
      "group_card",
      "hybrid"
    ]
  },
  "sync_avatar_on_switch": {
    "description": "修改 QQ 头像",
    "hint": "是否在切换人格时改变 QQ 头像(仅适配NapCat!!!)",
    "type": "bool",
    "default": false
  },
  "nickname_template": {
    "description": "昵称模板",
    "hint": "更改昵称时使用的模板，支持 {persona_id}(人格ID) 占位符",
    "type": "string",
    "default": "[B0T]{persona_id}"
  }
}
